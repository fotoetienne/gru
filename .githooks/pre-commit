#!/bin/bash
# Pre-commit hook for Gru project
# Runs code quality checks before allowing a commit

# Note: Not using 'set -e' because we handle errors explicitly with if statements

# Color codes for output
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

echo "🔍 Running pre-commit checks..."

# Verify this is a Rust project
if [ ! -f "Cargo.toml" ]; then
    echo -e "${RED}✗ Error: Cargo.toml not found${NC}"
    echo "  This pre-commit hook is designed for Rust projects"
    echo "  Current directory: $(pwd)"
    exit 1
fi

# Get current branch name
BRANCH=$(git rev-parse --abbrev-ref HEAD)

# 1. Prevent direct commits to main/master
if [ "$BRANCH" = "main" ] || [ "$BRANCH" = "master" ]; then
    echo -e "${RED}✗ Direct commits to '$BRANCH' branch are not allowed${NC}"
    echo "  Please create a feature branch instead:"
    echo "  git checkout -b feature/your-feature-name"
    echo ""
    echo "  To bypass this check (use with caution):"
    echo "  git commit --no-verify"
    exit 1
fi

# 2. Check code formatting
echo "📝 Checking code formatting..."
if ! just fmt-check; then
    echo -e "${RED}✗ Code formatting check failed${NC}"
    echo "  Run 'just fmt' to fix formatting"
    echo ""
    echo "  To bypass this check (not recommended):"
    echo "  git commit --no-verify"
    exit 1
fi
echo -e "${GREEN}✓ Code formatting looks good${NC}"

# 3. Run clippy linter
echo "🔍 Running clippy linter..."
if ! just lint; then
    echo -e "${RED}✗ Clippy found issues${NC}"
    echo "  Fix the issues above before committing"
    echo ""
    echo "  To bypass this check (not recommended):"
    echo "  git commit --no-verify"
    exit 1
fi
echo -e "${GREEN}✓ Clippy checks passed${NC}"

# 4. Run tests
echo "🧪 Running tests..."
if ! just test; then
    echo -e "${RED}✗ Tests failed${NC}"
    echo "  Fix the failing tests before committing"
    echo ""
    echo "  To bypass this check (not recommended):"
    echo "  git commit --no-verify"
    exit 1
fi
echo -e "${GREEN}✓ All tests passed${NC}"

# 5. Check for TODO/FIXME comments (warning only)
echo "📋 Checking for TODO/FIXME comments..."
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)
if [ -n "$STAGED_FILES" ]; then
    # Use -z and xargs -0 to safely handle filenames with special characters
    if git diff --cached --name-only -z --diff-filter=ACMR | xargs -0 grep -l "TODO\|FIXME" 2>/dev/null; then
        echo -e "${YELLOW}⚠ Found TODO/FIXME comments in staged files${NC}"
        git diff --cached --name-only -z --diff-filter=ACMR | xargs -0 grep -n "TODO\|FIXME" 2>/dev/null || true
        echo "  This is just a reminder - commit will proceed"
    else
        echo -e "${GREEN}✓ No TODO/FIXME comments found${NC}"
    fi
else
    echo -e "${GREEN}✓ No staged files to check${NC}"
fi

echo ""
echo -e "${GREEN}✅ All pre-commit checks passed!${NC}"
echo ""
